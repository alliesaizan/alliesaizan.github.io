anti_join(stop_words) %>%
group_by(track_title, year) %>%
count(word, sort = TRUE) %>%
summarise(average_rep = mean(n))
# Plotting (2)
plotting <- data.songlength.3 %>%
group_by(year) %>%
summarise(average_rep = mean(average_rep))
