count(word, sort = TRUE)
k <- 5
ldaOut.terms <- read.csv(file=paste("/Users/alliesaizan/Documents/R-Tinkering/TSwift Lyrics/LDAGibbs_k=",k,"_TopicsToTerms.csv"))
#topicProbabilities <- read.csv(file=paste0("LDAGibbs_k=",k,"_TopicProbabilities.csv"))
#topic1ToTopic2 <- read.csv(file=paste0("LDAGibbs_k=",k,"_Topic1ToTopic2.csv"))
ldaOut.topics <- read.csv(file=paste("/Users/alliesaizan/Documents/R-Tinkering/TSwift Lyrics/LDAGibbs_k=",k,"_Topics.csv"))
topics <- data.frame(ldaOut.topics)
# Merge topics by song category to main data frame
datV2 <- cbind(datV2, topics)
datV2$V1 <- as.factor(datV2$V1)
plotting <- datV2 %>%
select(year, V1) %>%
group_by(year,V1) %>%
summarise(count = n())
# Plot results
hchart(plotting, "line", hcaes(x = year, y = count, group = V1),
color = c("#815BFF","#957FEF","#DEC0F1","#EFD9CE","#2F242C")) %>%
hc_title(text = "Topics Across Years") %>%
hc_add_theme(hc_theme_flat())
